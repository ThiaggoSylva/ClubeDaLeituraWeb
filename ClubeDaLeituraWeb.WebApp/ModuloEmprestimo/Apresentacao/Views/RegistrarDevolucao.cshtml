@using ClubeDaLeituraWeb.WebApp.ModuloEmprestimo.Apresentacao.Models

@model RegistrarDevolucaoViewModel

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Registrar Devolução";
}

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card shadow border-0 rounded-4">

                <div class="card-header bg-success text-white rounded-top-4 py-3">

                    <h3 class="mb-0 fw-semibold">
                        Registrar Devolução
                    </h3>

                </div>

                <div class="card-body p-4">

                    <form method="post">

                        <input type="hidden"
                               asp-for="Id" />

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Amigo
                            </label>

                            <input class="form-control form-control-lg rounded-3"
                                   value="@Model.Amigo"
                                   disabled />

                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-semibold">
                                Revista
                            </label>

                            <input class="form-control form-control-lg rounded-3"
                                   value="@Model.Revista"
                                   disabled />

                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">

                            <a asp-action="ListarAbertos"
                               class="btn btn-outline-secondary rounded-pill px-4">

                                Voltar

                            </a>

                            <button type="submit"
                                    class="btn btn-success rounded-pill px-4">

                                Confirmar Devolução

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>
