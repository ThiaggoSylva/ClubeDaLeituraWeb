@using ClubeDaLeituraWeb.WebApp.ModuloEmprestimo.Apresentacao.Models

@model List<ListarEmprestimoViewModel>

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Empréstimos Finalizados";
}

<div class="container py-4">

    <div class="card shadow border-0 rounded-4">

        <div class="card-header bg-dark text-white rounded-top-4 py-3">

            <h3 class="mb-0 fw-semibold">
                Empréstimos Finalizados
            </h3>

        </div>

        <div class="card-body p-4">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>
                            <th>Amigo</th>
                            <th>Revista</th>
                            <th>Data Empréstimo</th>
                            <th>Data Devolução</th>
                            <th>Status</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var emprestimo in Model)
                        {
                            <tr>

                                <td>@emprestimo.Amigo</td>

                                <td>@emprestimo.Revista</td>

                                <td>
                                    @emprestimo.DataEmprestimo.ToShortDateString()
                                </td>

                                <td>
                                    @emprestimo.DataDevolucao.ToShortDateString()
                                </td>

                                <td>

                                    <span class="badge bg-secondary rounded-pill px-3 py-2">

                                        @emprestimo.Status

                                    </span>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>
