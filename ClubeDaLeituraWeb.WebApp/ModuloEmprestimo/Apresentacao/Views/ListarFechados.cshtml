@using ClubeDaLeituraWeb.WebApp.ModuloEmprestimo.Apresentacao.Models
@model List<ListarEmprestimoViewModel>

@{
    ViewBag.Titulo = "Empréstimos Finalizados";
}

<h2 class="mb-4">@ViewBag.Titulo</h2>

<table class="table table-striped table-hover">

    <thead class="table-dark">
        <tr>
            <th>Amigo</th>
            <th>Revista</th>
            <th>Empréstimo</th>
            <th>Devolução</th>
            <th>Status</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var e in Model)
        {
            <tr>

                <td>@e.Amigo</td>

                <td>@e.Revista</td>

                <td>
                    @e.DataEmprestimo.ToShortDateString()
                </td>

                <td>
                    @e.DataDevolucao.ToShortDateString()
                </td>

                <td>@e.Status</td>

            </tr>
        }

    </tbody>

</table>

