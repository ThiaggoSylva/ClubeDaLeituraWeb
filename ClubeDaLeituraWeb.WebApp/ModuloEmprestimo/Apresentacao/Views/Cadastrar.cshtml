@using ClubeDaLeituraWeb.WebApp.ModuloEmprestimo.Apresentacao.Models

@model CadastrarEmprestimoViewModel

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastrar Empréstimo";
}

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card shadow border-0 rounded-4">

                <div class="card-header bg-primary text-white rounded-top-4 py-3">

                    <h3 class="mb-0 fw-semibold">
                        Cadastrar Empréstimo
                    </h3>

                </div>

                <div class="card-body p-4">

                    <form method="post">

                        <div asp-validation-summary="All"
                             class="alert alert-danger mb-4">
                        </div>

                        <div class="mb-4">

                            <label asp-for="AmigoId"
                                   class="form-label fw-semibold">
                            </label>

                            <select asp-for="AmigoId"
                                    class="form-select form-select-lg rounded-3">

                                <option value="">
                                    Selecione um amigo
                                </option>

                                @foreach (var amigo in Model.Amigos)
                                {
                                    <option value="@amigo.Id">
                                        @amigo.Nome
                                    </option>
                                }

                            </select>

                        </div>

                        <div class="mb-4">

                            <label asp-for="RevistaId"
                                   class="form-label fw-semibold">
                            </label>

                            <select asp-for="RevistaId"
                                    class="form-select form-select-lg rounded-3">

                                <option value="">
                                    Selecione uma revista
                                </option>

                                @foreach (var revista in Model.Revistas)
                                {
                                    <option value="@revista.Id">
                                        @revista.Titulo
                                    </option>
                                }

                            </select>

                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">

                            <a asp-action="ListarAbertos"
                               class="btn btn-outline-primary rounded-pill px-4">
                                Voltar
                            </a>

                            <button type="submit"
                                    class="btn btn-primary rounded-pill px-4">
                                Salvar
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>
