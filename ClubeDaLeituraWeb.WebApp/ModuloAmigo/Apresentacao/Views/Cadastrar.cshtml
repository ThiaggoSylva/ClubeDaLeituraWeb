@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Amigo";
}



@model CadastrarAmigoViewModel

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-header bg-primary text-white rounded-top-4 py-3">
                    <h3 class="mb-0 fw-semibold">
                        Cadastro de Amigo
                    </h3>
                </div>

                <div class="card-body p-4">

                    <form asp-action="Cadastrar" method="post">

                        <div class="mb-4">

                            <label asp-for="Nome"
                                   class="form-label fw-semibold text-primary text-uppercase small">
                                Nome
                            </label>

                            <input asp-for="Nome"
                                   class="form-control form-control-lg rounded-3"
                                   placeholder="Digite o nome do amigo" />

                            <span asp-validation-for="Nome"
                                  class="text-danger small fw-semibold"></span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="NomeResponsavel"
                                   class="form-label fw-semibold text-primary text-uppercase small">
                                Responsável
                            </label>

                            <input asp-for="NomeResponsavel"
                                   class="form-control form-control-lg rounded-3"
                                   placeholder="Digite o nome do responsável" />

                            <span asp-validation-for="NomeResponsavel"
                                  class="text-danger small fw-semibold"></span>

                        </div>

                        <div class="mb-4">

                            <label asp-for="Telefone"
                                   class="form-label fw-semibold text-primary text-uppercase small">
                                Telefone
                            </label>

                            <input asp-for="Telefone"
                                   class="form-control form-control-lg rounded-3"
                                   placeholder="(85) 99999-9999" />

                            <span asp-validation-for="Telefone"
                                  class="text-danger small fw-semibold"></span>

                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">

                            <a class="btn btn-outline-primary rounded-pill px-4"
                               asp-action="Listar">
                                Voltar
                            </a>

                            <button class="btn btn-primary rounded-pill px-4"
                                    type="submit">
                                Confirmar
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>
