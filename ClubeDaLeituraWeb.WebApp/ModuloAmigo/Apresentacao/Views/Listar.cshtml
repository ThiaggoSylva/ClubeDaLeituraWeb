@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Amigos";
}

@model List<ListarAmigosViewModel>

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div>
            <h2 class="fw-bold text-primary mb-1">
                Amigos
            </h2>

            <p class="text-secondary mb-0">
                Gerencie os amigos cadastrados no sistema
            </p>
        </div>

        <a class="btn btn-primary rounded-pill px-4 shadow-sm"
           asp-action="Cadastrar">
            Novo Amigo
        </a>

    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-primary border-0 shadow-sm rounded-4 p-4">

            <h5 class="fw-semibold mb-2">
                Nenhum amigo cadastrado
            </h5>

            <p class="mb-0">
                Clique em <strong>Novo Amigo</strong> para realizar o primeiro cadastro.
            </p>

        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

            <div class="table-responsive">

                <table class="table table-hover align-middle mb-0">

                    <thead class="table-primary">

                        <tr>
                            <th>ID</th>
                            <th>Nome</th>
                            <th>Responsável</th>
                            <th>Telefone</th>
                            <th width="200">Ações</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (ListarAmigosViewModel a in Model)
                        {
                            <tr>

                                <td>@a.Id</td>

                                <td class="fw-semibold">
                                    @a.Nome
                                </td>

                                <td>
                                    @a.NomeResponsavel
                                </td>

                                <td>
                                    @a.Telefone
                                </td>

                                <td>

                                    <div class="d-flex gap-2">

                                        <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                                           asp-action="Editar"
                                           asp-route-id="@a.Id">
                                            Editar
                                        </a>

                                        <a class="btn btn-outline-danger btn-sm rounded-pill px-3"
                                           asp-action="Excluir"
                                           asp-route-id="@a.Id">
                                            Excluir
                                        </a>

                                    </div>

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>
    }

</div>
