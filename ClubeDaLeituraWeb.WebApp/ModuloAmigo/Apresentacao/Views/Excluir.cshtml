@{
    Layout = "_Layout";
    ViewBag.Titulo = "Excluir Amigo";
}

@model ExcluirAmigoViewModel

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-lg-7">

            <div class="card border-0 shadow-lg rounded-4">

                <div class="card-header bg-danger text-white rounded-top-4 py-3">

                    <h3 class="mb-0 fw-semibold">
                        Excluir Amigo
                    </h3>

                </div>

                <div class="card-body p-4">

                    <div class="alert alert-danger rounded-4 border-0 shadow-sm">

                        <h5 class="fw-bold mb-2">
                            Atenção!
                        </h5>

                        <p class="mb-0">
                            Você está prestes a excluir este amigo permanentemente.
                        </p>

                    </div>

                    <form asp-action="ExcluirConfirmado"
                          asp-route-id="@Model.Id"
                          method="post">

                        <div class="mb-4">

                            <label class="form-label fw-semibold text-primary text-uppercase small">
                                Nome
                            </label>

                            <input class="form-control form-control-lg rounded-3"
                                   value="@Model.Nome"
                                   disabled />

                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-semibold text-primary text-uppercase small">
                                Responsável
                            </label>

                            <input class="form-control form-control-lg rounded-3"
                                   value="@Model.NomeResponsavel"
                                   disabled />

                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-semibold text-primary text-uppercase small">
                                Telefone
                            </label>

                            <input class="form-control form-control-lg rounded-3"
                                   value="@Model.Telefone"
                                   disabled />

                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">

                            <a class="btn btn-outline-secondary rounded-pill px-4"
                               asp-action="Listar">
                                Cancelar
                            </a>

                            <button class="btn btn-danger rounded-pill px-4"
                                    type="submit">
                                Confirmar Exclusão
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>
