@{
    Layout = "_Layout";
    ViewBag.Titulo = "Editar Revista";
    List<SelectListItem> caixas = ViewBag.Caixas;
}

@model EditarRevistaViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4"
      style="max-width: 620px;"
      asp-action="Editar"
      method="post">

    <input type="hidden" asp-for="id" />

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">
            Título
        </label>

        <input asp-for="titulo" class="form-control" />

        <span asp-validation-for="titulo"
              class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">
            Número da Edição
        </label>

        <input asp-for="numeroEdicao"
               type="number"
               min="1"
               class="form-control" />

        <span asp-validation-for="numeroEdicao"
              class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">
            Ano de Publicação
        </label>

        <input asp-for="anoPublicacao"
               type="number"
               class="form-control" />

        <span asp-validation-for="anoPublicacao"
              class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label class="form-label fw-semibold text-primary text-uppercase small">
            Caixa
        </label>

        <select asp-for="caixaId" class="form-select">
            <option value="">Selecione uma caixa</option>

            @foreach (var item in caixas)
            {
                <option value="@item.Value"
                        selected="@(item.Value == Model.caixaId)">
                    @item.Text
                </option>
            }
        </select>

        <span asp-validation-for="caixaId"
              class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">

        <a class="btn btn-outline-primary rounded-pill px-4"
           asp-action="Listar">
            Voltar
        </a>

        <button class="btn btn-primary rounded-pill px-4"
                type="submit">
            Confirmar
        </button>

    </div>

</form>
